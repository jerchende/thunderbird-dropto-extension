{
  "manifest_version": 2,
  "name": "DropTo",
  "version": "0.0.0",
  "author": "Johannes Erchen",
  "description": "Legt E-Mail-Anhänge per Kontextmenü mit einem Klick in vordefinierte Ordner ab. Pro Konto lassen sich mehrere Ziele festlegen, die als Untermenü erscheinen.",
  "homepage_url": "https://github.com/jerchende/thunderbird-dropto-extension",
  "browser_specific_settings": {
    "gecko": {
      "id": "dropto@jerchende.github.io",
      "strict_min_version": "115.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "64": "icons/icon-64.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "messagesRead",
    "accountsRead",
    "menus",
    "notifications",
    "storage"
  ],
  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  },
  "background": {
    "scripts": ["background.js"]
  },
  "experiment_apis": {
    "droptoFs": {
      "schema": "experiments/filesystem/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["droptoFs"]],
        "script": "experiments/filesystem/implementation.js"
      }
    }
  }
}
